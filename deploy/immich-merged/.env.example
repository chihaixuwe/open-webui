POSTGRES_USER=immich
POSTGRES_PASSWORD=change_me
POSTGRES_DB=immich
# Base URL for Immich server (reachable from WebUI container)
IMMICH_BASE_URL=http://immich-server:3001

# Secret used to sign JWTs in WebUI. Set Immich's JWT secret to the same value
# so Immich will accept tokens issued by WebUI.
WEBUI_SECRET_KEY=change_this_secret

